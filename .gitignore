# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Heavy Assets (Managed via GitHub Releases / External Hosting)
# Allow these as requested by user
!**/*.zip
!**/*.mov
!**/*.mp4
!**/*.pdf

# But exclude the specific massive files that exceed GitHub's 100MB limit
Screen Recording*.mov
public/media/temp-mail-agent.mov

# typescript
